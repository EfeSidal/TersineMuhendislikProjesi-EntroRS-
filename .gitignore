# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Bizimki bir executable (CLI aracı) olduğu için Cargo.lock commit'lenmelidir, o yüzden buraya yazmıyoruz.

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which contain debugging information
*.pdb

# IDE ve OS Dosyaları
.vscode/
.idea/
.DS_Store